# WebRTC Signaling Server Dockerfile
# 使用 Node.js 轻量级镜像
FROM node:20-alpine

# 设置工作目录
WORKDIR /app

# 使用腾讯云 npm 镜像加速
RUN npm config set registry https://mirrors.cloud.tencent.com/npm/

# 安装 socket.io
RUN npm init -y && npm install socket.io

# 复制 signaling server
COPY signaling-server.js ./

# 暴露 9000 端口
EXPOSE 9000

# 设置环境变量
ENV NODE_ENV=production
ENV PORT=9000
ENV HOST=0.0.0.0

# 启动 signaling server
CMD ["node", "signaling-server.js"]

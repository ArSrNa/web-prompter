# WebRTC Signaling Server Dockerfile
# 使用提供的镜像（已包含 Bun + Node.js）
FROM docker.cnb.cool/arsrna/dev-image/nodejs

# 设置工作目录
WORKDIR /app

# 复制 package.json
COPY package.json ./

# 安装依赖（使用 bun）
RUN bun install

# 复制信令服务器代码（TypeScript）
COPY signaling-server.ts ./

# 安装 socket.io 和类型定义
RUN bun add socket.io && bun add -d @types/node

# 暴露 9000 端口
EXPOSE 9000

# 设置环境变量
ENV NODE_ENV=production
ENV PORT=9000
ENV HOST=0.0.0.0

# 使用 Bun 运行 TypeScript（Bun 原生支持 TS）
CMD ["bun", "signaling-server.ts"]
